        {
          "name": "GET /auth/me — invalid token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// NOTE: DummyJSON returns 500 instead of 401 for a malformed/invalid token.",
                  "// This is an API bug — the correct status for an invalid credential is 401.",
                  "// Test is written to match actual API behaviour, not the expected behaviour.",
                  "pm.test('Status is 500 (API bug: should be 401)', function () {",
                  "    pm.response.to.have.status(500);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test('Response contains error message', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('message');",
                  "    pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Response does not expose user data', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.not.have.property('username');",
                  "    pm.expect(json).to.not.have.property('email');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer thisisnotavalidtoken.fakejwt.abc123"
              }
            ],
