    {
      "name": "Products",
      "item": [
        {
          "name": "GET all products",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test('Response contains products array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('products');",
                  "    pm.expect(json.products).to.be.an('array').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Pagination fields are present and are numbers', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('total');",
                  "    pm.expect(json).to.have.property('skip');",
                  "    pm.expect(json).to.have.property('limit');",
                  "    pm.expect(json.total).to.be.a('number');",
                  "    pm.expect(json.skip).to.be.a('number');",
                  "    pm.expect(json.limit).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('total is greater than 0', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.total).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('products array length does not exceed limit', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.products.length).to.be.at.most(json.limit);",
                  "});",
                  "",
                  "pm.test('Each product has required fields', function () {",
                  "    var json = pm.response.json();",
                  "    json.products.forEach(function (product) {",
                  "        pm.expect(product).to.have.property('id');",
                  "        pm.expect(product).to.have.property('title');",
                  "        pm.expect(product).to.have.property('price');",
                  "        pm.expect(product).to.have.property('category');",
                  "    });",
                  "});"
                ]
              }
            }
          ],
